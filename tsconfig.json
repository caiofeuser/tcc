{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"strict": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"types": ["node"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
    "paths" : {
      "@/*": ["./src/*"],
      "@db/*": ["./db/*"],
      "@log/*": ["./logger/*"]
      
    },
    "outDir": "./dist"
	},
	"exclude": ["node_modules"],
  "types": ["node", "bun"]
}
